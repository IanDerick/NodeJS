<div class="card">
    <h1>Cadastrar Usuário</h1>

    {{#if errors}}
        <div class="error">
            <strong>Corrija os erros abaixo:</strong>
            <ul>
                {{#each errors}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
        </div>
    {{/if}}

    <form action="/usuarios" method="POST">
        <p>
            <label>Nome</label><br/>
            <input type="text" name="nome" placeholder="Nome" value="{{values.nome}}" required />
        </p>
        <p>
            <label>Email</label><br/>
            <input type="email" name="email" placeholder="Email" value="{{values.email}}" required />
        </p>
        <button type="submit">Enviar</button>
    </form>
</div>
